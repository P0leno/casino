BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://shelloch.xyz,https://www.shelloch.xyz,https://api.shelloch.xyz

# Comma-separated list of admin user IDs
ADMIN_IDS=1056148947

# Pyrogram API credentials (для отправки подарков)
# 1. Получите API_ID и API_HASH на https://my.telegram.org
# 2. Запустите: python3 app/create_sess.py
# 3. Скопируйте полученный SESSION_STRING сюда
API_ID=12345678
API_HASH=your_api_hash_here
SESSION_STRING=your_session_string_here

# Log bot для отправки запросов на ручную выдачу
LOG_BOT_TOKEN=your_log_bot_token_here
LOGS_ID=-1002531573202
